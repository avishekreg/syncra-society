{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/app-version.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/downloads/android-update.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/downloads/syncra-society-latest.apk",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"syncra-society-latest.apk\""
        },
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        }
      ]
    },
    {
      "source": "/downloads/android.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/downloads/syncra-society-android.apk",
      "destination": "/downloads/syncra-society-latest.apk"
    },
    {
      "source": "/downloads/syncra-society-android-:build.apk",
      "destination": "/downloads/syncra-society-latest.apk"
    },
    {
      "source": "/((?!api(?:/|$)|downloads(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
