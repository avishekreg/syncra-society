# Vite reads NEXT_PUBLIC_* vars (see vite.config envPrefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional Vite-specific aliases
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Server-only (Next.js API on port 3000 — run npm run dev:api)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPER_ADMIN_SECRET=change-me-in-production
# Production n8n webhook (client + server)
N8N_WEBHOOK_URL=https://avishekreg-syncra-society.hf.space/webhook/syncra-society
VITE_N8N_WEBHOOK_URL=https://avishekreg-syncra-society.hf.space/webhook/syncra-society
ACTIVE_PAYMENT_GATEWAY=RAZORPAY
PAYMENT_GATEWAY_PUBLIC_KEY=rzp_test_placeholder
PAYMENT_GATEWAY_SECRET_KEY=rzp_secret_placeholder
RAZORPAY_WEBHOOK_SECRET=
